# Database
DATABASE_URL="postgresql://lorescryver:password@localhost:5432/lorescryver?schema=public"
DB_PASSWORD="replace-with-a-strong-password"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# AI Providers
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
# OPENAI_API_KEY=""      # Future: multi-provider support via Vercel AI SDK
# ANTHROPIC_API_KEY=""   # Future: multi-provider support via Vercel AI SDK

# Redis (rate limiting, sessions)
# In Docker: use redis://:PASSWORD@redis:6379
# Locally: use redis://localhost:6379
REDIS_URL="redis://:changeme@redis:6379"
REDIS_PASSWORD="changeme"
