generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  avatarUrl     String?
  plan          Plan      @default(FREE)
  projects      Project[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Plan {
  FREE
  PRO
  TEAM
}

// --- Enums ---

enum ProjectType {
  FOUNDATION
  DELIVERY
}

enum DeliveryFormat {
  NOVEL
  NOVELLA
  SHORT_STORY
  SCREENPLAY
  TV_SERIES
  WEB_SERIES
  STAGE_PLAY
  MUSICAL
  VIDEO_GAME
  VISUAL_NOVEL
  ANIMATION
  COMIC
  MANGA
  PODCAST
  TABLETOP_RPG
  INTERACTIVE_FICTION
  POETRY
  NONFICTION
  OTHER
}

enum ProjectStatus {
  IDEATION
  DRAFTING
  REVISION
  PUBLISHED
}

enum Phase {
  CONCEPT
  CANDIDATE
  CANON
}

enum Stage {
  BRAINSTORM
  RESEARCH
  REFERENCE
  CANON_STRESS_TEST
  EXPANSION_STRESS_TEST
  LOCKED
}

enum ChapterStatus {
  OUTLINE
  DRAFT
  REVISION
  FINAL
}

// --- Projects ---

model Project {
  id              String             @id @default(cuid())
  title           String
  type            ProjectType        @default(FOUNDATION)
  deliveryFormat  DeliveryFormat?
  status          ProjectStatus      @default(IDEATION)
  wordCountGoal   Int?               @default(80000)
  userId          String
  parentId        String?
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent          Project?           @relation("ProjectHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Project[]          @relation("ProjectHierarchy")
  chapters        Chapter[]
  bibleEntries    BibleEntry[]
  sections        ProjectSection[]
  stagingConcepts StagingConcept[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId])
  @@index([parentId])
}

// --- Project Sections (Lore Codex + Creation content) ---

model ProjectSection {
  id        String   @id @default(cuid())
  projectId String
  key       String
  content   String   @default("") @db.Text
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, key])
  @@index([projectId])
}

// --- Staging Concepts ---

model StagingConcept {
  id        String   @id @default(cuid())
  projectId String
  title     String   @default("New Brainstorm")
  summary   String   @default("") @db.Text
  phase     Phase    @default(CONCEPT)
  stage     Stage    @default(BRAINSTORM)
  tags      String[] @default([])
  messages  Json     @default("[]")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, phase])
}

// --- Chapters ---

model Chapter {
  id        String   @id @default(cuid())
  title     String
  order     Int
  content   Json     @default("{}")
  wordCount Int      @default(0)
  status    ChapterStatus @default(OUTLINE)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@unique([projectId, order])
}

// --- Series Bible ---

model BibleEntry {
  id          String   @id @default(cuid())
  type        String
  name        String
  description String   @default("")
  properties  Json     @default("{}")
  tags        String[] @default([])
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, type])
}
